# MindPal AI Backend
# Copy to .env and adjust

# Set to true to run WITHOUT MongoDB (in-memory store, data lost on restart). Default: true.
USE_IN_MEMORY_DB=true

# MongoDB (used only when USE_IN_MEMORY_DB=false)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=mindpal

# JWT (change in production!)
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# CORS (frontend origin)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Demo mode: use simulated AI (no HuggingFace/MediaPipe required)
DEMO_MODE=true

